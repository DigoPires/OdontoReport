# Database (configure after setting up PostgreSQL on Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/odontoreport

# NextAuth (required for Google OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# For ngrok (update NEXTAUTH_URL to your ngrok URL when using ngrok)
# Example: NEXTAUTH_URL=https://abc123.ngrok-free.app
NEXTAUTH_URL_INTERNAL=http://localhost:3000
